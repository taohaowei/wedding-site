# =====================================================================
# 部署变量样本 — 复制为 .env 后填实际值,.env 不进 git
# =====================================================================

# 后台密码(强密码,16 位以上;只保留在服务器和你本地的 .env)
ADMIN_PASSWORD=please-change-me-strong-and-long

# 任意 32 位以上随机串,用于 cookie 签名
SESSION_SECRET=please-change-me-32-random-chars-xxxxxxxxxxxx

# 申请 SSL 用的邮箱(Let's Encrypt 续期通知)
EMAIL=you@example.com

# 默认 SSH 用户(不传 ssh_user 参数时用这个)
DEFAULT_SSH_USER=root

# 域名(一般不用改;改的话 nginx/mynight.conf 也要同步改)
DOMAIN_PRIMARY=www.mynight.top
DOMAIN_ALIAS=mynight.top
